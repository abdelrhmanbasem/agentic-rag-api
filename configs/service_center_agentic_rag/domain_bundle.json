          "missing_fields": "BOOKING_MISSING_FIELDS",
          "missing_branch": "BOOKING_MISSING_BRANCH",
          "missing_date": "BOOKING_MISSING_DATE",
          "missing_full_name": "BOOKING_MISSING_FULL_NAME",
          "missing_plate_number": "BOOKING_MISSING_PLATE_NUMBER",
          "missing_name_and_plate": "BOOKING_MISSING_NAME_AND_PLATE",
          "slots_found": "BOOKING_SLOTS_FOUND",
          "choose_slot_again": "BOOKING_SLOT_SELECTION_UNCLEAR",
          "no_slots": "BOOKING_NO_SLOTS",
          "tool_error": "BOOKING_TOOL_ERROR",
          "confirm_slot": "BOOKING_CONFIRM_SELECTED_SLOT",
          "repeat_confirmation": "BOOKING_AWAITING_EXPLICIT_CONFIRMATION",
          "slot_rejected": "BOOKING_SLOT_REJECTED",
          "booking_confirmed": "BOOKING_CONFIRMED",
          "booking_failed": "BOOKING_FAILED",
          "booking_completed_closing": "BOOKING_COMPLETED_CLOSING",
          "booking_already_confirmed": "BOOKING_ALREADY_CONFIRMED"
        }
      },
      "troubleshooting": {
        "id": "troubleshooting",
        "name": "Troubleshooting state executor",
        "enabled": true,
        "goal": "Classify vehicle symptoms into service categories and maintain lightweight diagnostic state for the final response LLM.",
        "when_to_use": "Use when the customer describes a vehicle problem, symptom, noise, warning, weak performance, or safety concern, and is not directly asking to book.",
        "instructions": "Do not write final diagnostic wording. Detect the problem category, update service_needed and troubleshooting metadata, store possible causes/recommended questions, and let the graph response node generate the natural explanation and next diagnostic question.",
        "allowed_actions": [
          "classify_symptom",
          "update_diagnostic_state",
          "mark_inspection_recommended"
        ],
        "state_path": "troubleshooting.stage",
        "count_path": "troubleshooting.diagnostic_count",
        "selected_rule_path": "troubleshooting.selected_rule_id",
        "metadata_path": "troubleshooting",
        "inspection_recommended_path": "troubleshooting.inspection_recommended",
        "max_diagnostic_turns_before_visit_offer": 2,
        "active_state": "active",
        "complete_state": "complete",
        "variable_scope": {
          "include": [
            "troubleshooting",
            "service_needed",
            "selected_branch",
            "nearest_branch",
            "booking.stage"
          ]
        },
        "skip_if_paths_exist": [
          "selected_branch",
          "booking.stage"
        ],
        "direct_booking_phrases": [
          "احجز",
          "عايز احجز",
          "أحجز",
          "حجز",
          "عايز معاد",
          "عايز ميعاد",
          "عايز موعد",
          "مواعيد",
          "المواعيد",
          "book",
          "appointment"
        ],
        "templates": {
          "started": "TROUBLESHOOTING_STARTED",
          "continued": "TROUBLESHOOTING_CONTINUED",
          "complete": "TROUBLESHOOTING_READY_TO_RECOMMEND_INSPECTION",
          "default": "TROUBLESHOOTING_STATE_UPDATED"
        },
        "rules": [
          {
            "id": "brake_symptom_diagnostics",
            "category": "brakes",
            "expected_system": "Brakes & Safety",
            "phrases": [
              "فرامل",
              "الفرامل",
              "صفارة",
              "صوت",
              "تيل",
              "طنابير",
              "brake",
              "brakes"
            ],
            "variable_updates": {
              "service_needed": "Brakes & Safety"
            },
            "possible_causes": [
              "brake pad wear",
              "disc/rotor friction or glazing",
              "dust or debris around brake components",
              "caliper or hardware noise"
            ],
            "recommended_questions": [
              "Does the sound happen only while pressing the brakes?",
              "Is there vibration or weak braking?",
              "Does it happen more at low speed or after driving for a while?"
            ],
            "severity": "safety_related",
            "safety_note": "Brake issues can affect safety, so inspection is recommended if the sound is strong, repeated, or paired with vibration or weak braking.",
            "clear_variables": [
              "booking",
              "available_slots",
              "appointment_time",
              "customer_confirmed_booking"
            ]
          }
        ]
      }
    },
    "tool_update_rules": {
      "list_branches": {
        "set": {
          "available_branches": "result.branches",
          "available_branches_text": "result.branches_text"
        }
      },
      "find_nearest_branch": {
        "set": {
          "user_area": "result.user_area"
        },
        "conditional": [
          {
            "when": {
              "path": "result.branch_found",
              "equals": true
            },
            "set": {
              "nearest_branch": "result.branch",
              "location_branch": "result.branch",
              "selected_branch": "result.branch"
            }
          },
          {
            "when": {
              "path": "result.branch_found",
              "equals": false
            },
            "clear": [
              "nearest_branch",
              "location_branch",
              "selected_branch"
            ],
            "set": {
              "available_branches": "result.branches",
              "available_branches_text": "result.branches_text"
            }
          }
        ]
      },
      "list_available_slots": {
        "clear": [
          "booking.pending",
          "appointment_time"
        ],
        "set": {
          "selected_branch": "result.branch",
          "location_branch": "result.branch",
          "appointment_date": "result.date",
          "date_text": "result.date_text",
          "available_slots": "result.available_slots",
          "available_slots_text": "result.available_slots_text",
          "slots_found": "result.slots_found"
        },
        "conditional": [
          {
            "when": {
              "path": "result.slots_found",
              "equals": true
            },
            "set": {
              "booking.stage": "slot_selection"
            }
          },
          {
            "when": {
              "path": "result.slots_found",
              "equals": false
            },
            "set": {
              "booking.stage": "awaiting_date"
            }
          }
        ]
      },
      "check_availability": {
        "set": {
          "selected_branch": "result.branch",
          "appointment_date": "result.date",
          "date_text": "result.date_text",
          "appointment_time": "result.time",
          "exact_slot": "result.exact_slot",
          "nearest_slots": "result.nearest_slots",
          "nearest_slots_text": "result.nearest_slots_text",
          "unavailable_reason": "result.unavailable_reason"
        },
        "conditional": [
          {
            "when": {
              "path": "result.exact_slot_available",
              "equals": true
            },
            "set": {
              "booking.stage": "awaiting_confirmation",
              "booking.pending": "result.requested_slot",
              "customer_confirmed_booking": false
            }
          }
        ]
      },
      "create_booking": {
        "conditional": [
          {
            "when": {
              "path": "result.ok",
              "equals": true
            },
            "clear": [
              "booking.pending"
            ],
            "set": {
              "booking_status": "result.booking_status",
              "visit_id": "result.visit_id",
              "booking.confirmed": "result.booking",
              "booking.stage": "result.booking_status"
            }
          },
          {
            "when": {
              "path": "result.ok",
              "equals": false
            },
            "set": {
              "booking_status": "failed",
              "booking_error": "result.error",
              "booking.stage": "booking_failed"
            }
          }
        ]
      }
    }
  },
  "schema": {
    "assistant_id": "service_center_agentic_rag",
    "variables": {
