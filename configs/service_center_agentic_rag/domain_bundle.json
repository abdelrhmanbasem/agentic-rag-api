{
  "assistant": {
    "assistant_id": "service_center_agentic_rag",
    "model": "gpt-4o-mini",
    "temperature": 0.05,
    "max_tool_calls": 4,
    "assistant_goal": "Help customers diagnose car service issues, find suitable branches, check appointment availability, and book service visits only after explicit confirmation.",
    "language_policy": "Reply in the same language and dialect as the customer. For Egyptian Arabic, use natural Egyptian Arabic.",
    "system_prompt": "You are a helpful car service center assistant. Be direct, practical, and natural. Do not expose internal logic. Do not mention tools, JSON, variables, operations, or schemas. Never invent branches, dates, slots, unavailable reasons, or booking confirmations. Do not suggest checking appointment slots too early unless the user directly asks to book.",
    "response_rules": [
      "Do not offer booking immediately after the first symptom message. First ask diagnostic/discovery questions.",
      "For symptom cases, keep the first two assistant turns diagnostic/discovery before suggesting visit slots, unless the customer directly asks to book.",
      "After resolving nearest branch for a symptom case, do not automatically ask to check appointments. Explain the suitable branch and diagnostic recommendation only.",
      "A customer area is not a branch unless a tool confirms it.",
      "Never invent slots, branches, booking IDs, dates, or unavailable reasons.",
      "Never confirm booking unless create_booking returns ok=true.",
      "During an active booking flow, ask only for the next missing required information.",
      "If the customer directly asks to book or asks for appointments, the booking flow can start immediately.",
      "If the user says yes after being asked whether to check slots, ask for the day/date first unless date_text already exists.",
      "When waiting for slot selection, do not call tools again unless the user provides a new date or asks to change the day.",
      "When the user selects a time in Arabic words like عشرة الصبح, treat it as a slot selection if a matching available slot exists."
    ],
    "fallback_messages": {
      "empty_answer": "ممكن توضحلي أكتر؟",
      "max_tool_calls": "محتاج أتأكد من البيانات الأول. ممكن تعيد طلبك بشكل أوضح؟",
      "default_final": "محتاج تفاصيل أكتر عشان أساعدك."
    },
    "normalization": {
      "digit_map": {
        "٠": "0",
        "١": "1",
        "٢": "2",
        "٣": "3",
        "٤": "4",
        "٥": "5",
        "٦": "6",
        "٧": "7",
        "٨": "8",
        "٩": "9",
        "۰": "0",
        "۱": "1",
        "۲": "2",
        "۳": "3",
        "۴": "4",
        "۵": "5",
        "۶": "6",
        "۷": "7",
        "۸": "8",
        "۹": "9"
      },
      "replacements": {
        "أ": "ا",
        "إ": "ا",
        "آ": "ا",
        "ة": "ه",
        "ى": "ي"
      }
    },
    "subagent_order": [
      "handoff",
      "location",
      "booking",
      "lookup",
      "troubleshooting"
    ],
    "tools": [
      {
        "name": "service_center_sheet",
        "type": "http",
        "description": "Fetch service center branches, slots, and bookings.",
        "url": "https://script.google.com/macros/s/AKfycbx_Au3LPLNiZZ2gxJRp8nZcC6Vo8XUTXvymHJQOsgfgBW67dBRGHPLExbA3CTdZXR8W/exec",
        "method": "POST",
        "timeout_seconds": 30,
        "headers": {
          "Content-Type": "application/json"
        },
        "operations": {
          "list_branches": {
            "required": [],
            "optional": []
          },
          "find_nearest_branch": {
            "required": [
              "location"
            ],
            "optional": [
              "latitude",
              "longitude"
            ]
          },
          "list_available_slots": {
            "required": [
              "branch",
              "date_text"
            ],
            "optional": [
              "section",
              "limit"
            ]
          },
          "check_availability": {
            "required": [
              "branch",
              "date_text",
              "time"
            ],
            "optional": [
              "section"
            ]
          },
          "create_booking": {
            "required": [
              "branch",
              "date_text",
              "time",
              "section",
              "full_name",
              "phone",
              "plate_number",
              "customer_confirmed_booking"
            ],
            "optional": [
              "conversation_id",
              "user_id"
            ]
          }
        }
      }
    ],
    "subagents": {
      "handoff": {
        "enabled": true,
        "variable_scope": {
          "include": [
            "customer_profile",
            "booking",
            "selected_branch"
          ]
        },
        "trigger_phrases": [
          "اكلم حد",
          "موظف",
          "خدمة العملاء",
          "human",
          "agent"
        ],
        "answer_template": "تمام، هحوّلك لحد من الفريق يساعدك.",
        "variable_updates": {
          "handoff_requested": true
        },
        "clear_variables": []
      },
      "location": {
        "enabled": true,
        "tool_name": "service_center_sheet",
        "operation": "find_nearest_branch",
        "location_argument": "location",
        "user_area_path": "user_area",
        "nearest_branch_path": "nearest_branch",
        "location_branch_path": "location_branch",
        "selected_branch_path": "selected_branch",
        "set_selected_branch_on_match": true,
        "diagnostic_count_path": "troubleshooting.diagnostic_count",
        "min_diagnostic_turns_before_visit_offer": 2,
        "on_branch_found_after_diagnostics_updates": {},
        "on_branch_found_direct_booking_updates": {
          "booking.stage": "awaiting_date"
