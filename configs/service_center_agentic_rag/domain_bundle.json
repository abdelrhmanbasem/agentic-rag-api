  "domain_playbook": {
    "version": "2.1",
    "notes": [
      "Final customer-facing wording is handled by ResponseComposer LLM.",
      "Subagent templates are now intent labels/fallback hints, not scripted final replies.",
      "BookingSubagent controls deterministic safety only: state, extraction, slot selection, required fields, and tool calls.",
      "BookingSubagent does not contain customer-facing hardcoded Arabic replies.",
      "ResponseComposer must use variables and tool observations to create natural answers.",
      "Booking trigger phrases do not include broad words like المتاحة or متاح alone.",
      "availability_request_terms can include broad availability terms only inside slot_selection context when branch and date already exist.",
      "Lookup runs before booking so branch-list questions are not hijacked by booking.",
      "create_booking appends a row only after explicit confirmation and required details."
    ]
  }
