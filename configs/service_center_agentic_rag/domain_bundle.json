    "tool_update_rules": {
      "list_branches": {
        "clear": [
          "selected_branch",
          "nearest_branch",
          "location_branch",
          "available_slots",
          "booking"
        ],
        "set": {
          "available_branches": "result.branches",
          "available_branches_text": "result.branches_text"
        }
      },
      "find_nearest_branch": {
        "set": {
          "user_area": "result.user_area"
        },
        "conditional": [
          {
            "when": {
              "path": "result.branch_found",
              "equals": true
            },
            "set": {
              "nearest_branch": "result.branch",
              "location_branch": "result.branch",
              "selected_branch": "result.branch"
            }
          },
          {
            "when": {
              "path": "result.branch_found",
              "equals": false
            },
            "clear": [
              "nearest_branch",
              "location_branch",
              "selected_branch"
            ],
            "set": {
              "available_branches": "result.branches",
              "available_branches_text": "result.branches_text"
            }
          }
        ]
      },
      "list_available_slots": {
        "clear": [
          "booking.pending",
          "appointment_time"
        ],
        "set": {
          "selected_branch": "result.branch",
          "location_branch": "result.branch",
          "appointment_date": "result.date",
          "date_text": "result.date_text",
          "available_slots": "result.available_slots",
          "available_slots_text": "result.available_slots_text",
          "slots_found": "result.slots_found"
        },
        "conditional": [
          {
            "when": {
              "path": "result.slots_found",
              "equals": true
            },
            "set": {
              "booking.stage": "slot_selection"
            }
          },
          {
            "when": {
              "path": "result.slots_found",
              "equals": false
            },
            "set": {
              "booking.stage": "awaiting_date"
            }
          }
        ]
      },
      "check_availability": {
        "set": {
          "selected_branch": "result.branch",
          "appointment_date": "result.date",
          "date_text": "result.date_text",
          "appointment_time": "result.time",
          "exact_slot": "result.exact_slot",
          "nearest_slots": "result.nearest_slots",
          "nearest_slots_text": "result.nearest_slots_text",
          "unavailable_reason": "result.unavailable_reason"
        },
        "conditional": [
          {
            "when": {
              "path": "result.exact_slot_available",
              "equals": true
            },
            "set": {
              "booking.stage": "awaiting_confirmation",
              "booking.pending": "result.requested_slot",
              "customer_confirmed_booking": false
            }
          }
        ]
      },
      "create_booking": {
        "conditional": [
          {
            "when": {
              "path": "result.ok",
              "equals": true
            },
            "clear": [
              "booking.pending"
            ],
            "set": {
              "booking_status": "result.booking_status",
              "visit_id": "result.visit_id",
              "booking.confirmed": "result.booking",
              "booking.stage": "result.booking_status"
            }
          },
          {
            "when": {
              "path": "result.ok",
              "equals": false
            },
            "set": {
              "booking_status": "failed",
              "booking_error": "result.error",
              "booking.stage": "booking_failed"
            }
          }
        ]
      }
    }
  },
  "schema": {
    "assistant_id": "service_center_agentic_rag",
    "variables": {
      "customer_profile": {
        "type": "object",
        "properties": {
          "full_name": {
            "type": "string"
          },
          "phone": {
            "type": "string"
          },
          "plate_number": {
            "type": "string"
          }
        }
      },
      "booking": {
        "type": "object"
      },
      "troubleshooting": {
        "type": "object"
      },
      "user_area": {
        "type": "string"
      },
      "selected_branch": {
        "type": "string"
      },
      "nearest_branch": {
        "type": "string"
      },
      "location_branch": {
        "type": "string"
      },
      "date_text": {
        "type": "string"
      },
      "appointment_date": {
        "type": "string"
      },
      "appointment_time": {
        "type": "string"
      },
      "service_needed": {
        "type": "string"
      },
      "available_slots": {
        "type": "array"
      },
      "available_slots_text": {
        "type": "string"
      },
      "available_branches": {
        "type": "array"
      },
      "available_branches_text": {
        "type": "string"
      },
      "booking_status": {
        "type": "string"
      },
      "visit_id": {
        "type": "string"
      },
      "customer_confirmed_booking": {
        "type": "boolean"
      },
      "handoff_requested": {
        "type": "boolean"
      }
    }
  },
  "domain_playbook": {
    "version": "1.5",
    "notes": [
      "Location resolution is handled by the location subagent.",
      "Location no longer pushes appointment checking automatically after symptom branch resolution.",
      "Booking starts when the customer asks for appointments, slots, booking, or direct scheduling.",
      "Booking customer detail extraction only runs while booking.stage is awaiting_customer_details.",
      "The booking flow uses customer_profile.plate_number instead of plate_digits so Arabic plates like ب ج ١٧٩ can be captured.",
      "Arabic time words like عشرة الصبح are handled by booking_subagent.py.",
      "create_booking appends a row to the Bookings sheet only after explicit confirmation and required booking details."
    ]
  }
}
