            "service_needed",
            "selected_branch",
            "nearest_branch",
            "booking.stage"
          ]
        },
        "skip_if_paths_exist": [
          "selected_branch",
          "booking.stage"
        ],
        "direct_booking_phrases": [
          "احجز",
          "عايز احجز",
          "أحجز",
          "حجز",
          "عايز معاد",
          "عايز ميعاد",
          "عايز موعد",
          "مواعيد",
          "المواعيد",
          "book",
          "appointment"
        ],
        "rules": [
          {
            "id": "brake_symptom_diagnostics",
            "phrases": [
              "فرامل",
              "الفرامل",
              "صفارة",
              "صوت",
              "تيل",
              "طنابير",
              "brake",
              "brakes"
            ],
            "variable_updates": {
              "service_needed": "Brakes & Safety"
            },
            "clear_variables": [
              "booking",
              "available_slots",
              "appointment_time",
              "customer_confirmed_booking"
            ],
            "diagnostic_steps": [
              {
                "answer_template": "TROUBLESHOOTING_BRAKES_STEP_1"
              },
              {
                "answer_template": "TROUBLESHOOTING_BRAKES_STEP_2"
              },
              {
                "answer_template": "TROUBLESHOOTING_ASK_LOCATION_AFTER_VISIT_CONSENT",
                "complete": true
              }
            ]
          }
        ]
      }
    },
    "tool_update_rules": {
      "list_branches": {
        "clear": [
          "selected_branch",
          "nearest_branch",
          "location_branch",
          "available_slots",
          "booking"
        ],
        "set": {
          "available_branches": "result.branches",
          "available_branches_text": "result.branches_text"
        }
      },
      "find_nearest_branch": {
        "set": {
          "user_area": "result.user_area"
        },
        "conditional": [
          {
            "when": {
              "path": "result.branch_found",
              "equals": true
            },
            "set": {
              "nearest_branch": "result.branch",
              "location_branch": "result.branch",
              "selected_branch": "result.branch"
            }
          },
          {
            "when": {
              "path": "result.branch_found",
              "equals": false
            },
            "clear": [
              "nearest_branch",
              "location_branch",
              "selected_branch"
            ],
            "set": {
              "available_branches": "result.branches",
              "available_branches_text": "result.branches_text"
            }
          }
        ]
      },
      "list_available_slots": {
        "clear": [
          "booking.pending",
          "appointment_time"
        ],
        "set": {
          "selected_branch": "result.branch",
          "location_branch": "result.branch",
          "appointment_date": "result.date",
          "date_text": "result.date_text",
          "available_slots": "result.available_slots",
          "available_slots_text": "result.available_slots_text",
          "slots_found": "result.slots_found"
        },
        "conditional": [
          {
            "when": {
              "path": "result.slots_found",
              "equals": true
            },
            "set": {
              "booking.stage": "slot_selection"
            }
          },
          {
            "when": {
              "path": "result.slots_found",
              "equals": false
            },
            "set": {
              "booking.stage": "awaiting_date"
            }
          }
        ]
      },
      "check_availability": {
        "set": {
          "selected_branch": "result.branch",
          "appointment_date": "result.date",
          "date_text": "result.date_text",
          "appointment_time": "result.time",
          "exact_slot": "result.exact_slot",
          "nearest_slots": "result.nearest_slots",
          "nearest_slots_text": "result.nearest_slots_text",
          "unavailable_reason": "result.unavailable_reason"
        },
        "conditional": [
          {
            "when": {
              "path": "result.exact_slot_available",
              "equals": true
            },
            "set": {
              "booking.stage": "awaiting_confirmation",
              "booking.pending": "result.requested_slot",
              "customer_confirmed_booking": false
            }
          }
        ]
      },
      "create_booking": {
        "conditional": [
          {
            "when": {
              "path": "result.ok",
              "equals": true
            },
            "clear": [
              "booking.pending"
            ],
            "set": {
              "booking_status": "result.booking_status",
              "visit_id": "result.visit_id",
              "booking.confirmed": "result.booking",
              "booking.stage": "result.booking_status"
            }
          },
          {
            "when": {
              "path": "result.ok",
              "equals": false
            },
            "set": {
              "booking_status": "failed",
              "booking_error": "result.error",
              "booking.stage": "booking_failed"
            }
          }
        ]
      }
    }
  },
