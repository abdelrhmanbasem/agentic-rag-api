        "templates": {
          "branch_found": "أقرب فرع مناسب ليك هو فرع {{result.branch}}.",
          "branch_found_no_visit_offer": "أقرب فرع مناسب ليك هو فرع {{result.branch}}.",
          "branch_found_after_diagnostics": "أقرب فرع مناسب ليك هو فرع {{result.branch}}. وبالنسبة للصوت، الأفضل يتكشف عليه في قسم الفرامل عشان نطمن على التيل والطنابير.",
          "branch_found_direct_booking": "أقرب فرع مناسب ليك هو فرع {{result.branch}}. تحب الحجز في يوم إيه؟",
          "branch_not_found": "مش لاقي فرع مطابق لمنطقتك بشكل مؤكد. الفروع المتاحة:\n{{result.branches_text}}\nتحب تختار أنهي فرع؟",
          "tool_error": "حصلت مشكلة وأنا بحدد أقرب فرع. ممكن تجرب تاني؟",
          "fallback": "تمام، ممكن توضحلي منطقتك أكتر؟"
        }
      },
      "booking": {
        "enabled": true,
        "tool_name": "service_center_sheet",
        "stage_path": "booking.stage",
        "pending_booking_path": "booking.pending",
        "available_slots_path": "available_slots",
        "date_text_path": "date_text",
        "variable_scope": {
