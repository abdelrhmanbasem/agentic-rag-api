            "troubleshooting",
            "service_needed",
            "user_area",
            "nearest_branch",
            "location_branch",
            "selected_branch",
            "booking"
          ]
        },
        "location_patterns": [
          {
            "regex": "(?:انا ساكن في|أنا ساكن في|ساكن في|مكاني في|مكانى في|انا في|أنا في|في منطقة|منطقة|location is|i am in|i live in)\\s+([^\\n،,.!?؟]+)",
            "group": 1
          }
        ],
        "location_trigger_phrases": [
