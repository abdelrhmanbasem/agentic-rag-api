          "بكره",
          "بعد بكرة",
          "بعد بكره",
          "النهارده",
          "انهارده",
          "اليوم",
          "الخميس",
          "الجمعة",
          "الجمعه",
          "السبت",
          "الأحد",
          "الاحد",
          "الاثنين",
          "التلات",
          "الثلاثاء",
          "الأربعاء",
          "الاربعاء"
        ],
        "date_extraction_patterns": [
          {
            "regex": "(?:يوم|ميعاد|معاد|تاريخ|مواعيد)\\s+([^\\n،,.!?؟]+)",
            "group": 1
          },
          {
            "regex": "(\\d{1,2}\\s*(?:يناير|فبراير|مارس|ابريل|أبريل|مايو|يونيو|يونيه|يوليو|يوليه|اغسطس|أغسطس|سبتمبر|اكتوبر|أكتوبر|نوفمبر|ديسمبر))",
            "group": 1
          },
          {
            "regex": "(\\d{4}-\\d{2}-\\d{2})",
            "group": 1
          }
        ],
        "confirmation_phrases": [
          "اه",
          "أه",
          "ايوه",
          "أيوه",
          "نعم",
          "تمام",
          "مظبوط",
          "صح",
          "اكيد",
          "أكيد",
          "اوكي",
          "أوكي",
          "أكد",
          "اكد",
          "confirm",
          "confirmed",
          "yes",
          "ok",
          "okay"
        ],
        "rejection_phrases": [
          "لا",
          "لأ",
          "مش مناسب",
          "غير",
          "لا شكرا",
          "no",
          "cancel"
        ],
        "extraction_patterns": [
          {
            "variable": "customer_profile.full_name",
            "regex": "(?:اسمي|انا اسمي|الاسم|الإسم|name is|my name is)\\s+([^\\n،,.]+)",
            "group": 1
          },
          {
            "variable": "customer_profile.phone",
            "regex": "(01\\d{9}|\\+?20\\d{10,11})",
            "group": 1
          },
          {
            "variable": "customer_profile.plate_number",
            "regex": "(?:رقم العربية|نمر العربية|نمرة العربية|رقم اللوحه|رقم اللوحة|اللوحه|اللوحة|لوحتي|لوحتى|plate)\\D*([\\u0600-\\u06FFa-zA-Z]{1,4}(?:\\s+[\\u0600-\\u06FFa-zA-Z]{1,4}){0,4}\\s*[\\d٠-٩۰-۹]{1,8})",
            "group": 1
          },
          {
            "variable": "customer_profile.plate_number",
            "regex": "(?:رقم العربية|نمر العربية|نمرة العربية|رقم اللوحه|رقم اللوحة|اللوحه|اللوحة|لوحتي|لوحتى|plate)\\D*([\\u0600-\\u06FFa-zA-Z\\s]{0,16}[\\d٠-٩۰-۹][\\d\\s٠-٩۰-۹]{0,10})",
            "group": 1
          },
          {
            "variable": "customer_profile.plate_number",
            "regex": "^\\s*([\\u0600-\\u06FFa-zA-Z]{1,4}(?:\\s+[\\u0600-\\u06FFa-zA-Z]{1,4}){0,4}\\s*[\\d٠-٩۰-۹]{1,8})\\s*$",
            "group": 1,
            "when_missing": "customer_profile.plate_number"
          },
          {
            "variable": "customer_profile.plate_number",
            "regex": "^\\s*(\\d{2,8})\\s*$",
            "group": 1,
            "when_missing": "customer_profile.plate_number"
          },
          {
            "variable": "customer_profile.full_name",
            "regex": "^\\s*([\\u0600-\\u06FFa-zA-Z]{2,}(?:\\s+[\\u0600-\\u06FFa-zA-Z]{2,}){0,4})\\s*$",
            "group": 1,
            "when_missing": "customer_profile.full_name"
          }
        ],
        "time_normalization": {
          "regex": "(\\d{1,2})(?::(\\d{2}))?\\s*(am|pm)?",
